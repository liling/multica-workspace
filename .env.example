# Multica daemon 认证令牌（必填）
# 在 Multica 平台生成：Cloud Node PAT (mcn_...) 推荐，或用户 PAT (mul_...)
# 这是 daemon 实际消费的认证来源。复制本文件为 .env 并填入真实令牌。
MULTICA_TOKEN=mcn_xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：只监听指定工作区；留空则监听账号下全部工作区
MULTICA_WORKSPACE_ID=

# 可选：自托管服务器地址（默认 https://api.multica.ai）
# MULTICA_SERVER_URL=https://api.multica.ai

# 注意：本文件必须是 KEY=VALUE 形式，不要加 export 前缀，也不要用引号包裹。
# 必须与 docker-compose.yml 放在同一目录，才能被 docker compose 自动加载。
